{
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,
  "files.insertFinalNewline": true,
  "files.associations": {
    ".env.*": "dotenv"
  },
  "files.exclude": {
    "**/bun.lockb": true,
    "**/node_modules": true,
    "**/*.tsbuildinfo": true,
    "**/*.db-wal": true,
    "**/*.db-shm": true,
    "**/dist": true,
    "**/coverage": true,
    "**/.vendor": true
  }
}
