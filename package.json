{
  "name": "openkitten",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Telegram-first AI agent with 75+ AI providers, OS-level sandbox, and built-in capabilities people actually need.",
  "main": "lib/main.ts",
  "scripts": {
    "prepare": "bun prepare.ts",
    "compile": "bun compile.ts",
