    "up": "bun . up",
    "down": "bun . down"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.4.0",
    "lefthook": "^2.1.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "citty": "^0.2.1"
  }
}
