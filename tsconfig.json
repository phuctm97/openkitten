{
  "include": ["prepare.ts"],
  "references": [
    { "path": "./packages/bot/api/tsconfig.json" },
    { "path": "./packages/bot/cli/tsconfig.json" },
    { "path": "./packages/server/tsconfig.json" },
    { "path": "./packages/website/tsconfig.json" },
    { "path": "./packages/world/tsconfig.json" }
  ],
  "extends": "@tsconfig/bun/tsconfig.json",
  "compilerOptions": {
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": true,
    "noEmit": false,
    "composite": true,
    "allowImportingTsExtensions": false,
    "emitDeclarationOnly": true,
    "types": ["bun"],
    "outDir": "dist"
  }
}
