{
  "name": "@openkitten/world-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "lib/main.ts",
  "scripts": {
    "dev": "bun --env-file=../../../../.env.local --watch --no-clear-screen .",
    "test": "bun --bun vitest run",
    "auth:generate": "bun run --env-file=../../../../.env.local --bun -- bunx @better-auth/cli@latest generate --config lib/auth.tsx --output lib/schema/auth.ts -y",
    "drizzle:generate": "bun --bun drizzle-kit generate"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.9",
    "@openkitten/world-contract": "workspace:*",
    "@openkitten/world-util": "workspace:*",
    "@orpc/server": "^1.14.0",
    "@simplewebauthn/server": "^13.3.0",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "nodemailer": "^8.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-email": "^6.0.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@react-email/ui": "^6.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-istanbul": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
