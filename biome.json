{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "indentStyle": "space"
  },
  "linter": {
    "rules": {
      "style": {
        "noRestrictedImports": {
          "level": "warn",
          "options": {
            "patterns": [
              {
                "group": ["./*", "../*"],
                "message": "Use ~/* path aliases instead of relative imports."
              }
            ]
          }
        }
      }
    }
  }
}
